# 自动处理行尾符
* text=auto

# C# 项目文件使用 CRLF
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.csx text eol=crlf

# 文档和配置使用 LF
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf

# 图片使用二进制
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# PHP 文件使用 LF
*.php text eol=lf
